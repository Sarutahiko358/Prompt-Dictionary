        {
            "name": "margin-inline / margin-block",
            "label": "CSS",
            "labelClass": "label-css",
            "desc": "論理的なマージンを指定する。margin-inlineは書字方向のインライン軸（LTRなら左右）、margin-blockはブロック軸（通常は上下）。国際化対応に有用。",
            "demo": "<div style=\"background:#f0f0f0;padding:4px\"><div style=\"margin-inline:auto;width:180px;background:#dbeafe;padding:8px;font-size:0.8rem;text-align:center\">margin-inline: auto（中央寄せ）</div><div style=\"margin-block:12px;background:#dcfce7;padding:8px;font-size:0.8rem\">margin-block: 12px（上下余白）</div></div>",
            "code": ".center {\n  margin-inline: auto;\n}\n.section {\n  margin-block: 2rem;\n}\n.aside {\n  margin-inline-start: 1rem;\n}",
            "props": [
                {
                    "name": "margin-inline-start",
                    "desc": "インライン軸の開始側（LTRなら左）"
                },
                {
                    "name": "margin-inline-end",
                    "desc": "インライン軸の終了側（LTRなら右）"
                },
                {
                    "name": "margin-block-start",
                    "desc": "ブロック軸の開始側（通常は上）"
                },
                {
                    "name": "margin-block-end",
                    "desc": "ブロック軸の終了側（通常は下）"
                }
            ],
            "tags": [
