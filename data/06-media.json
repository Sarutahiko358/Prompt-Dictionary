        {
            "name": "&lt;iframe&gt;",
            "label": "HTML",
            "labelClass": "label-html",
            "desc": "外部ページやウィジェットを埋め込むインラインフレーム。YouTube動画、Googleマップ、SNS投稿などの埋め込みに広く使用される。sandbox 属性でセキュリティ制限をかけられる。",
            "demo": "<div style=\"font-size:0.85rem\"><div style=\"width:200px;aspect-ratio:16/9;background:#1e293b;border-radius:8px;display:flex;align-items:center;justify-content:center;color:#94a3b8;border:2px solid #334155\"><span style=\"font-size:0.8rem\">iframe 埋め込み領域</span></div><p style=\"margin:4px 0 0;color:#6b7280;font-size:0.75rem\">※セキュリティのためデモでは実際の埋め込みは行いません</p></div>",
            "code": "<!-- YouTube 埋め込み -->\n<iframe src=\"https://www.youtube.com/embed/VIDEO_ID\"\n        width=\"560\" height=\"315\"\n        title=\"動画タイトル\"\n        loading=\"lazy\"\n        allow=\"accelerometer; autoplay;\n               clipboard-write; encrypted-media;\n               gyroscope; picture-in-picture\"\n        allowfullscreen>\n</iframe>\n\n<!-- サンドボックス付き -->\n<iframe src=\"https://example.com\"\n        sandbox=\"allow-scripts allow-same-origin\"\n        title=\"埋め込みコンテンツ\">\n</iframe>",
            "props": [
                {
                    "name": "src",
                    "desc": "埋め込むページのURL"
                },
                {
                    "name": "title",
                    "desc": "フレームの説明（a11y必須）"
                },
                {
                    "name": "sandbox",
                    "desc": "セキュリティ制限（allow-scripts 等）"
                },
                {
                    "name": "allow",
                    "desc": "許可する機能ポリシー"
                },
                {
                    "name": "loading",
                    "desc": "lazy で遅延読み込み"
                },
                {
                    "name": "allowfullscreen",
                    "desc": "フルスクリーンを許可"
                }
            ],
            "tags": [
                "埋め込み",
                "動画",
                "外部コンテンツ"
            ],
            "browser": "全ブラウザ対応",
            "mdn": "https://developer.mozilla.org/ja/docs/Web/HTML/Element/iframe"
        },
        {
            "name": "&lt;svg&gt; インラインSVG",
            "label": "HTML",
            "labelClass": "label-html",
            "desc": "スケーラブル・ベクター・グラフィックスをHTMLに直接埋め込む。拡大してもぼやけず、CSSやJSでの操作・アニメーションが可能。アイコン、ロゴ、グラフなどに最適。",
            "demo": "<svg width=\"120\" height=\"60\" viewBox=\"0 0 120 60\" xmlns=\"http://www.w3.org/2000/svg\" style=\"font-size:0.85rem\"><rect x=\"2\" y=\"2\" width=\"116\" height=\"56\" rx=\"8\" fill=\"#eff6ff\" stroke=\"#3b82f6\" stroke-width=\"2\" /><circle cx=\"30\" cy=\"30\" r=\"12\" fill=\"#3b82f6\" /><rect x=\"55\" y=\"18\" width=\"24\" height=\"24\" rx=\"4\" fill=\"#10b981\" /><polygon points=\"100,18 112,42 88,42\" fill=\"#f59e0b\" /></svg>",
            "code": "<!-- インライン SVG -->\n<svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\"\n     fill=\"none\" stroke=\"currentColor\"\n     stroke-width=\"2\">\n  <circle cx=\"12\" cy=\"12\" r=\"10\" />\n  <path d=\"M12 8v4l3 3\" />\n</svg>\n\n<!-- CSS でスタイリング -->\n<style>\n  svg { color: #3b82f6; }\n  svg:hover { color: #2563eb; }\n</style>",
            "props": [
                {
                    "name": "viewBox",
                    "desc": "SVG座標系の定義（min-x min-y width height）"
                },
                {
                    "name": "width / height",
                    "desc": "表示サイズ"
                },
                {
                    "name": "fill",
                    "desc": "塗りつぶし色"
                },
                {
                    "name": "stroke",
                    "desc": "線の色"
                },
                {
                    "name": "currentColor",
                    "desc": "CSSのcolorプロパティの値を継承"
                }
            ],
            "tags": [
                "SVG",
                "アイコン",
                "グラフィック"
            ],
            "browser": "全ブラウザ対応",
            "mdn": "https://developer.mozilla.org/ja/docs/Web/SVG/Element/svg"
        },
        {
            "name": "&lt;canvas&gt;",
            "label": "HTML",
            "labelClass": "label-html",
            "desc": "JavaScript で2Dグラフィックスやアニメーションを描画するためのビットマップ描画領域。グラフ、ゲーム、画像加工などに使用される。WebGL で3D描画も可能。",
            "demo": "<canvas id=\"demo-canvas\" width=\"200\" height=\"80\" style=\"border:1px solid #e2e8f0;border-radius:8px;background:#fafafa\"></canvas><script>(function(){var c=document.getElementById('demo-canvas');if(!c)return;var ctx=c.getContext('2d');ctx.fillStyle='#3b82f6';ctx.fillRect(10,10,40,60);ctx.fillStyle='#10b981';ctx.fillRect(60,25,40,45);ctx.fillStyle='#f59e0b';ctx.fillRect(110,15,40,55);ctx.fillStyle='#ef4444';ctx.beginPath();ctx.arc(170,45,20,0,Math.PI*2);ctx.fill()})()</script>",
            "code": "<canvas id=\"myCanvas\" width=\"400\" height=\"300\">\n  Canvas非対応ブラウザ用テキスト\n</canvas>\n\n<script>\n  const canvas = document.getElementById('myCanvas');\n  const ctx = canvas.getContext('2d');\n\n  // 矩形\n  ctx.fillStyle = '#3b82f6';\n  ctx.fillRect(10, 10, 100, 80);\n\n  // 円\n  ctx.beginPath();\n  ctx.arc(200, 50, 40, 0, Math.PI * 2);\n  ctx.fillStyle = '#10b981';\n  ctx.fill();\n\n  // テキスト\n  ctx.font = '16px sans-serif';\n  ctx.fillStyle = '#000';\n  ctx.fillText('Hello Canvas', 10, 120);\n</script>",
            "props": [
                {
                    "name": "width / height",
                    "desc": "描画領域のサイズ（CSSではなく属性で指定）"
                },
                {
                    "name": "getContext('2d')",
                    "desc": "2D描画コンテキストを取得"
                },
                {
                    "name": "getContext('webgl')",
                    "desc": "WebGL 3D描画コンテキスト"
                },
                {
                    "name": "toDataURL()",
                    "desc": "キャンバス内容をData URLに変換"
                }
            ],
            "tags": [
                "グラフィック",
                "JavaScript",
                "描画"
            ],
            "browser": "全ブラウザ対応",
            "mdn": "https://developer.mozilla.org/ja/docs/Web/HTML/Element/canvas"
        },
        {
            "name": "CSS background-image",
            "label": "CSS",
