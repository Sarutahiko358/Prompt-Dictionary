        {
            "name": "キーボードナビゲーション パターン",
            "label": "JS",
            "labelClass": "label-js",
            "desc": "カスタムウィジェットで適切なキーボード操作を実装するためのパターン。矢印キーでの選択移動、Escapeでの閉じ操作、Enter/Spaceでの実行など、WAI-ARIAオーサリング・プラクティスに準拠した実装が求められる。",
            "demo": "<div style=\"font-size:0.85rem\"><div role=\"listbox\" aria-label=\"フルーツ選択\" style=\"border:1px solid #cbd5e1;border-radius:8px;overflow:hidden;max-width:200px\" id=\"kbList\"><style>.kb-opt{padding:8px 12px;cursor:pointer;outline:none;transition:background 0.1s}.kb-opt:focus,.kb-opt[aria-selected=true]{background:#dbeafe;color:#1d4ed8;font-weight:700}.kb-opt:hover{background:#f1f5f9}</style><div role=\"option\" class=\"kb-opt\" tabindex=\"0\" aria-selected=\"true\">🍎 りんご</div><div role=\"option\" class=\"kb-opt\" tabindex=\"-1\" aria-selected=\"false\">🍊 みかん</div><div role=\"option\" class=\"kb-opt\" tabindex=\"-1\" aria-selected=\"false\">🍇 ぶどう</div></div><span style=\"color:#64748b;font-size:0.75rem\">↑↓キーで移動、Enter で選択</span><script>(function(){try{var items=document.querySelectorAll('#kbList .kb-opt');items.forEach(function(item,i){item.addEventListener('keydown',function(e){var idx=-1;if(e.key==='ArrowDown'){idx=Math.min(i+1,items.length-1)}else if(e.key==='ArrowUp'){idx=Math.max(i-1,0)}if(idx>=0){items.forEach(function(el){el.setAttribute('tabindex','-1');el.setAttribute('aria-selected','false')});items[idx].setAttribute('tabindex','0');items[idx].setAttribute('aria-selected','true');items[idx].focus();e.preventDefault()}});})}catch(e){}})()</script></div>",
            "code": "// ロービング tabindex パターン\n// （リスト/タブ/メニューで使用）\nconst items = document.querySelectorAll('[role=\"tab\"]');\nlet currentIndex = 0;\n\nfunction focusItem(index) {\n  items.forEach((item, i) => {\n    item.setAttribute('tabindex', i === index ? '0' : '-1');\n    item.setAttribute('aria-selected', i === index);\n  });\n  items[index].focus();\n  currentIndex = index;\n}\n\nitems.forEach((item, i) => {\n  item.addEventListener('keydown', (e) => {\n    switch (e.key) {\n      case 'ArrowRight':\n      case 'ArrowDown':\n        e.preventDefault();\n        focusItem((i + 1) % items.length);\n        break;\n      case 'ArrowLeft':\n      case 'ArrowUp':\n        e.preventDefault();\n        focusItem((i - 1 + items.length) % items.length);\n        break;\n      case 'Home':\n        e.preventDefault();\n        focusItem(0);\n        break;\n      case 'End':\n        e.preventDefault();\n        focusItem(items.length - 1);\n        break;\n      case 'Enter':\n      case ' ':\n        e.preventDefault();\n        activateItem(i);\n        break;\n    }\n  });\n});",
            "props": [
