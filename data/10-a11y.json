        {
            "name": "&lt;label&gt; と for 属性",
            "label": "HTML",
            "labelClass": "label-html",
            "desc": "フォームコントロールにアクセシブルなラベルを関連付ける。for属性でinputのidを指定するか、labelでinputを囲む。ラベルクリックでフォーカスが移動し、操作領域が広がる。",
            "demo": "<div style=\"font-size:0.85rem;display:flex;flex-direction:column;gap:12px\"><div><label for=\"demo-name\" style=\"font-weight:700;color:#334155;display:block;margin-bottom:4px\">名前（ラベルをクリック→フォーカス）</label><input type=\"text\" id=\"demo-name\" placeholder=\"入力してください\" style=\"padding:6px 10px;border:1px solid #cbd5e1;border-radius:6px;font-size:0.85rem;width:200px\"></div><label style=\"display:flex;align-items:center;gap:8px;cursor:pointer\"><input type=\"checkbox\" style=\"width:16px;height:16px\"><span>暗黙的ラベル（inputを囲む方法）</span></label></div>",
            "code": "<!-- 明示的ラベル（for で紐付け） -->\n<label for=\"email\">メールアドレス</label>\n<input type=\"email\" id=\"email\" \n       placeholder=\"user@example.com\">\n\n<!-- 暗黙的ラベル（label で囲む） -->\n<label>\n  <input type=\"checkbox\">\n  利用規約に同意する\n</label>\n\n<!-- ⚠️ placeholder はラベルの代替にならない -->\n<!-- ❌ -->\n<input placeholder=\"名前\">\n<!-- ✅ -->\n<label for=\"name\">名前</label>\n<input id=\"name\" placeholder=\"例: 田中太郎\">\n\n<!-- 必須表示 -->\n<label for=\"phone\">\n  電話番号 <span aria-hidden=\"true\">*</span>\n  <span class=\"visually-hidden\">（必須）</span>\n</label>\n<input id=\"phone\" required \n       aria-required=\"true\">",
            "props": [
